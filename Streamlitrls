            if CACHE_OK and not force_refresh:
                cache  = FDCCache(cache_dir=CACHE_DIR)
                fdc_df = fetch_fdc_data_cached(
                    cache=cache, fetch_fn=fetch_fdc,
                    equip_id=equip_id, chamber=chamber,
                    param_names=selected_params, ch_steps=selected_steps,
                    change_dates=change_dates, start_dt=start_dt, end_dt=end_dt,
                    force_refresh=False,
                )
                if "last_query_count" not in st.session_state or st.session_state.get("last_query_sampled") is None:
                    st.session_state["last_query_count"]   = len(fdc_df)
                    st.session_state["last_query_sampled"] = False
            else:
                fdc_df = fetch_fdc(
                    equip_id=equip_id, chamber=chamber,
                    param_names=selected_params, ch_steps=selected_steps,
                    change_dates=change_dates, start_dt=start_dt, end_dt=end_dt,
                )
        _query_elapsed = time.time() - _t_query_start
        st.session_state["last_query_elapsed"] = _query_elapsed

        if fdc_df.empty:
            st.warning("FDC 데이터 없음 → 설비/기간/파라미터 설정 확인해줘")
            return

        # 세션에 저장
        st.session_state["fdc_result"] = {
            "fdc_df":          fdc_df,
            "history_df":      history_df,
            "equip_id":        equip_id,
            "chamber":         chamber,
            "part_name":       part_name,
            "selected_params": selected_params,
            "selected_steps":  selected_steps,
            "selected_charts": selected_charts,
            "change_dates":    change_dates,
            "start_dt":        start_dt,
            "end_dt":          end_dt,
        }

    # 결과 렌더
    if "fdc_result" in st.session_state:
        r = st.session_state["fdc_result"]
        fdc_df         = r["fdc_df"]
        history_df     = r["history_df"]
        equip_id       = r["equip_id"]
        chamber        = r["chamber"]
        part_name      = r["part_name"]
        selected_params = r["selected_params"]
        selected_steps  = r["selected_steps"]
        selected_charts = r.get("selected_charts") or ["📈 Line Plot"]
        change_dates    = r["change_dates"]
        start_dt        = r["start_dt"]
        end_dt          = r["end_dt"]

        # ── 조회 건수 / 샘플링 / 소요시간 배너 ──────────────
        total_count = st.session_state.get("last_query_count", 0)
        sampled     = st.session_state.get("last_query_sampled", False)
        elapsed     = st.session_state.get("last_query_elapsed", 0)

        # 시간 포맷 (1분 이상이면 분:초, 아니면 초)
        def _fmt_time(sec):
            if sec >= 60:
                return "{}분 {:02.0f}초".format(int(sec // 60), sec % 60)
            return "{:.1f}초".format(sec)

        if sampled and total_count > 0:
            st.markdown(
                '<div class="warn-box">'
                '⚠️ 전체 <b>{:,}건</b> 중 최대 {:,}건으로 샘플링됨 '
                '(교체 전/후 각 {:,}건 균등 추출) — '
                '정밀 분석이 필요하면 기간을 줄여줘! &nbsp;|&nbsp; ⏱ 조회 {}'
                '</div>'.format(total_count, MAX_ROWS, MAX_ROWS // 2, _fmt_time(elapsed)),
                unsafe_allow_html=True,
            )
        elif total_count > 0:
            st.markdown(
                '<div class="info-box">'
                '✅ 총 <b>{:,}건</b> 조회됨 &nbsp;|&nbsp; ⏱ 조회 {}'
                '</div>'.format(len(fdc_df), _fmt_time(elapsed)),
                unsafe_allow_html=True,
            )

        period_label = "{} ~ {}".format(
            start_dt.strftime("%Y.%m.%d"),
            end_dt.strftime("%Y.%m.%d"),
        )

        # 파라미터별 탭
        if len(selected_params) > 1:
            tabs = st.tabs(selected_params)
        else:
            tabs = [st.container()]

        for ti, param in enumerate(selected_params):
            with tabs[ti]:
                _t_render = time.time()
                df_result = extract_before_after(
                    fdc_df, history_df, equip_id, chamber,
                    part_name, param, start_dt, end_dt,
                )
                if df_result.empty:
                    st.warning("{} 데이터 없음".format(param))
                    continue

                df_result = mark_out_of_spec(df_result)
                stats     = calc_statistics(df_result)
                _render_elapsed = time.time() - _t_render

                # 교체이력 없음 안내
                if "교체이력없음" in df_result["event_label"].iloc[0]:
                    st.markdown('<div class="warn-box">⚠️ 선택 기간 내 교체 이력 없음 → 전체 FDC 데이터 표시</div>', unsafe_allow_html=True)

                # 파라미터별 소요시간 표시
                st.caption("⏱ {} 렌더: {} · 데이터 {:,}건".format(
                    param, _fmt_time(_render_elapsed), len(df_result)
                ))

                # 통계 카드
                render_stat_cards(stats)
                st.markdown("")

                # 태그
                tags_html = ""
                tags_html += '<span class="tag tag-blue">{}</span>'.format(equip_id)
                tags_html += '<span class="tag tag-blue">Chamber {}</span>'.format(chamber)
                tags_html += '<span class="tag tag-blue">{}</span>'.format(part_name)
                if change_dates:
                    for cd in change_dates:
                        if pd.Timestamp(start_dt) <= cd <= pd.Timestamp(end_dt):
                            tags_html += '<span class="tag tag-blue">교체 {}</span>'.format(cd.strftime("%Y.%m.%d"))
                upper = df_result["upper_spec"].dropna()
                lower = df_result["lower_spec"].dropna()
                if not upper.empty:
                    tags_html += '<span class="tag tag-red">USL: {}</span>'.format(round(upper.mean(),4))
                if not lower.empty:
                    tags_html += '<span class="tag tag-red">LSL: {}</span>'.format(round(lower.mean(),4))
                tags_html += '<span class="tag">{}</span>'.format(period_label)
                st.markdown(tags_html, unsafe_allow_html=True)
                st.markdown("")

                # ch_step 목록
                steps = sorted(df_result["ch_step"].dropna().unique()) if "ch_step" in df_result.columns else ["ALL"]
                if not steps:
                    steps = ["ALL"]

                base_title = "{}-{} [{}] {}".format(equip_id, chamber, part_name, param)

                # 차트 렌더
                for chart_name in selected_charts:
                    chart_key = CHART_FUNCS.get(chart_name)
                    chart_title = "{} - {}".format(base_title, chart_name)

                    st.markdown(
                        '<div class="chart-section-header">{}</div>'.format(chart_name),
                        unsafe_allow_html=True
                    )
                    c1, c2 = st.columns([10, 1])
                    with c2:
                        save_key = "save_{}_{}".format(ti, chart_key)
                        if st.button("💾", key=save_key, help="HTML로 저장"):
                            st.session_state["save_{}_{}".format(ti, chart_key)] = True

                    fig = None
                    if   chart_key == "line":        fig = chart_line(df_result, param, steps, change_dates, chart_title)
                    elif chart_key == "scatter":     fig = chart_scatter(df_result, param, steps, change_dates, chart_title)
                    elif chart_key == "box":         fig = chart_box(df_result, param, chart_title)
                    elif chart_key == "violin":      fig = chart_violin(df_result, param, chart_title)
                    elif chart_key == "histogram":   fig = chart_histogram(df_result, param, chart_title)
                    elif chart_key == "bar":         fig = chart_bar(df_result, param, chart_title)
                    elif chart_key == "heatmap":     fig = chart_heatmap(df_result, param, chart_title)
                    elif chart_key == "bubble":      fig = chart_bubble(df_result, param, change_dates, chart_title)
                    elif chart_key == "control":     fig = chart_control(df_result, param, change_dates, chart_title)
                    elif chart_key == "change_rate": fig = chart_change_rate(df_result, param, chart_title)

                    if fig:
                        st.plotly_chart(fig, use_container_width=True, config=PLOTLY_CONFIG)
                        # HTML 저장
                        if st.session_state.get("save_{}_{}".format(ti, chart_key)):
                            path = save_html(fig, chart_title)
                            st.success("저장 완료: {}".format(path))
                            st.session_state.pop("save_{}_{}".format(ti, chart_key))
                    else:
                        st.warning("{} 차트 생성 불가 (데이터 부족)".format(chart_name))


if __name__ == "__main__":
    main()
