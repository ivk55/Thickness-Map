        color = BA_COLORS.get(ba, COLOR_BEFORE)
        sub   = df[df["before_after"] == ba].sort_values("act_time")
        if sub.empty: continue
        mean = sub["param_value"].mean()
        std  = sub["param_value"].std()
        std  = 0.0 if (pd.isna(std) or std == 0) else std
        in_s  = sub[~sub["out_of_spec"]]
        out_s = sub[sub["out_of_spec"]]
        nin   = "{} In Spec".format(ba)
        noos  = "{} OOS".format(ba)
        if not in_s.empty:
            fig.add_trace(go.Scatter(x=in_s["act_time"], y=in_s["param_value"],
                mode="lines+markers", name=nin, legendgroup=ba,
                showlegend=(nin not in legend_shown),
                line=dict(color=color, width=1.5), marker=dict(size=4, color=color),
                hovertemplate=build_hovertemplates(in_s, param)))
            legend_shown.add(nin)
        if not out_s.empty:
            fig.add_trace(go.Scatter(x=out_s["act_time"], y=out_s["param_value"],
                mode="markers", name=noos, legendgroup=ba,
                showlegend=(noos not in legend_shown),
                marker=dict(size=10, color=COLOR_OUT_SPEC, symbol="x"),
                hovertemplate=build_hovertemplates(out_s, param)))
            legend_shown.add(noos)
        for y_val, label, dash in [
            (mean,           "Mean({})={:.3f}".format(ba, mean),      "dash"),
            (mean + 3 * std, "+3σ({})={:.3f}".format(ba, mean+3*std), "dot"),
            (mean - 3 * std, "-3σ({})={:.3f}".format(ba, mean-3*std), "dot"),
        ]:
            # std=0이면 ±3σ가 mean과 겹치므로 mean만 표시
            if std == 0 and y_val != mean:
                continue
            fig.add_hline(y=y_val, line_dash=dash, line_color=color, line_width=1,
                          annotation_text=label, annotation_position="right")
    add_spec_lines(fig, df)
    add_change_vlines(fig, change_dates)
    layout = base_layout(title)
    layout["xaxis"]["title"] = "act_time"
    layout["yaxis"]["title"] = param
    fig.update_layout(**layout)
    return fig


def chart_change_rate(df, param, title):
    events, rates, colors = [], [], []
    for event_label, group in df.groupby("event_label"):
        b = group[group["before_after"] == "Before"]["param_value"].mean()
        a = group[group["before_after"] == "After"]["param_value"].mean()
        if pd.notna(b) and pd.notna(a) and abs(b) > 1e-10:
            rate = (a - b) / abs(b) * 100
            events.append(event_label)
            rates.append(round(rate, 2))
            colors.append(COLOR_AFTER if rate > 0 else COLOR_BEFORE)
    if not events:
        return None
    fig = go.Figure(go.Bar(
        x=events, y=rates, marker_color=colors, opacity=0.85,
        text=["{}%".format(r) for r in rates], textposition="outside",
        hovertemplate="이벤트: %{x}<br>변화율: %{y:.2f}%<extra></extra>",
    ))
    fig.add_hline(y=0, line_color="#8B949E", line_width=1)
    layout = base_layout(title)
    layout["xaxis"] = dict(
        gridcolor="#EDF2F7", linecolor="#E2E8F0",
        tickfont=dict(size=11, color="#4A5568"), tickangle=-25,
    )
    layout["yaxis"]["title"] = "변화율 (%)"
    fig.update_layout(**layout)
    return fig


