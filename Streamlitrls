    date_str = datetime.now().strftime("%Y%m%d_%H%M")
    safe = (title.replace(" ", "_").replace("/", "-").replace(":", "-")
            .replace("[","").replace("]","").replace("~","-"))
    path = os.path.join(OUTPUT_DIR, "{}_{}.html".format(safe, date_str))
