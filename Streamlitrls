BA_COLORS = {"Before": COLOR_BEFORE, "After": COLOR_AFTER, "전체": COLOR_BEFORE}


def _insert_gaps(x_list, y_list, hover_list, gap_minutes=30):
    """
    act_time 간격이 gap_minutes 이상이면 None 삽입 → 선 자동 끊김
    x_list: datetime 리스트, y_list: 값 리스트, hover_list: hover 리스트
    """
    if len(x_list) < 2:
        return x_list, y_list, hover_list

    new_x, new_y, new_h = [], [], []
    gap = pd.Timedelta(minutes=gap_minutes)

    for i, (x, y, h) in enumerate(zip(x_list, y_list, hover_list)):
        if i > 0:
            prev_x = pd.Timestamp(x_list[i - 1])
            curr_x = pd.Timestamp(x)
            if (curr_x - prev_x) >= gap:
                # gap 삽입 → 선 끊김
                new_x.append(None)
                new_y.append(None)
                new_h.append("<extra></extra>")
        new_x.append(x)
        new_y.append(y)
        new_h.append(h)

    return new_x, new_y, new_h


def make_segmented_line(sdf, param, step_name, change_dates, legend_shown):
    """
    Before/After 구간을 각각 끊어서 trace 생성
    - 30분 이상 gap → 선 자동 끊김 (None 삽입)
    - Before: 파랑, After: 빨강
    - legend: DEP1_A1(Before) 형식
    - OOS: 보라 X 마커
    """
    traces = []

    for ba, color in [("Before", COLOR_BEFORE), ("After", COLOR_AFTER), ("전체", COLOR_BEFORE)]:
        sub = sdf[sdf["before_after"] == ba].sort_values("act_time")
        if sub.empty:
            continue

        in_s  = sub[~sub["out_of_spec"]]
        out_s = sub[sub["out_of_spec"]]

        if ba == "전체":
            legend_name = step_name if step_name != "ALL" else "전체"
        else:
            legend_name = "{} ({})".format(step_name, ba) if step_name != "ALL" else ba

        show_lg = legend_name not in legend_shown

        if not in_s.empty:
            x_raw   = in_s["act_time"].tolist()
            y_raw   = in_s["param_value"].tolist()
            h_raw   = build_hovertemplates(in_s, param)
            # 30분 이상 gap → None 삽입으로 선 끊기
            x_gap, y_gap, h_gap = _insert_gaps(x_raw, y_raw, h_raw, gap_minutes=30)
            traces.append({
                "x": x_gap,
                "y": y_gap,
                "color": color,
                "name": legend_name,
                "showlegend": show_lg,
                "mode": "lines+markers",
                "hover": h_gap,
                "marker_size": 4,
                "is_oos": False,
            })
            legend_shown.add(legend_name)

        if not out_s.empty:
            oos_name = "{} OOS".format(step_name) if step_name != "ALL" else "OOS"
            show_oos = oos_name not in legend_shown
            traces.append({
                "x": out_s["act_time"].tolist(),
                "y": out_s["param_value"].tolist(),
                "color": COLOR_OUT_SPEC,
                "name": oos_name,
                "showlegend": show_oos,
                "mode": "markers",
                "hover": build_hovertemplates(out_s, param),
                "marker_size": 9,
                "is_oos": True,
            })
            legend_shown.add(oos_name)

    return traces


def chart_line(df, param, steps, change_dates, title):
    """오버레이 고정: 선택된 step을 한 그래프에 겹쳐서 표시"""
    legend_shown = set()
    fig = go.Figure()

    for step in steps:
        sdf = df[df["ch_step"] == step] if step != "ALL" else df
        step_name = step if step != "ALL" else "ALL"
        traces = make_segmented_line(sdf, param, step_name, change_dates, legend_shown)
        for t in traces:
            if t["is_oos"]:
                fig.add_trace(go.Scatter(
                    x=t["x"], y=t["y"],
                    mode=t["mode"], name=t["name"],
                    showlegend=t["showlegend"],
                    marker=dict(size=t["marker_size"], color=t["color"], symbol="x"),
                    hovertemplate=t["hover"],
                ))
            else:
                fig.add_trace(go.Scatter(
                    x=t["x"], y=t["y"],
                    mode=t["mode"], name=t["name"],
                    showlegend=t["showlegend"],
                    line=dict(color=t["color"], width=2),
