@st.cache_data(show_spinner=False)
def cached_load_excel(path, _mtime):
    """Excel 이력 로드 - 파일 수정시간 기반 캐시 (파일 바뀌면 자동 재로드)"""
    if not XLWINGS_OK:
        return pd.DataFrame()
    if not os.path.exists(path):
        return pd.DataFrame()
    app = xw.App(visible=False)
    try:
        wb       = app.books.open(path)
        all_data = []
        for sheet in wb.sheets:
            try:
                last_row = sheet.range("A1").end("down").row
                if last_row < 2:
                    continue
                data = sheet.range("A2:E{}".format(last_row)).value
                for row in data:
                    if not row or row[0] is None:
                        continue
                    all_data.append({
                        "equip_id":    str(row[0]).strip().upper(),
                        "chamber":     str(row[1]).strip().upper() if row[1] else "",
                        "part_name":   str(row[2]).strip().upper() if row[2] else "",
                        "part_type":   str(row[3]).strip()         if row[3] else "",
                        "change_date": pd.to_datetime(row[4])      if row[4] else None,
                    })
            except Exception:
                pass
        wb.close()
    finally:
        app.quit()
    if not all_data:
        return pd.DataFrame()
    return pd.DataFrame(all_data).dropna(subset=["change_date"])


@st.cache_data(ttl=1800, show_spinner=False)
def cached_fetch_params(equip_id):
    """param_name 목록 조회 (30분 캐시)"""
    if not BDQ_OK:
        return ["ESC_CURRENT_AVG_T", "RF_POWER_FWD", "PRESSURE_AVG", "GAS_FLOW_SIH4"]
    def _q(interval):
        sql = (
            "WITH base AS ("
            "  SELECT unnest(param_name) AS param_name"
            "  FROM fab.m_erdtsum_data_agg"
            "  WHERE line_id IN ('PFBP','PFPB') AND eqp_id='{}'"
            "    AND area='CVD' AND create_time >= now() - INTERVAL {}"
            ") SELECT DISTINCT UPPER(param_name) AS param_name FROM base"
            " WHERE param_name IS NOT NULL ORDER BY UPPER(param_name)"
        ).format(equip_id, interval)
        try:
            r = bdq.getData(sql)
            if not isinstance(r, pd.DataFrame): r = pd.DataFrame(r)
            return [] if r.empty else r["param_name"].dropna().str.strip().tolist()
        except Exception:
            return []
    params = _q("2 HOUR")
    if not params:
        params = _q("24 HOUR")
    return params


