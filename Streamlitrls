def extract_before_after(fdc_df, history_df, equip_id, chamber, part_name, param_name, start_dt, end_dt):
    start_ts = pd.Timestamp(start_dt)
    end_ts   = pd.Timestamp(end_dt)

    fdc = fdc_df[fdc_df["param_name"] == param_name.upper()].copy()
    if fdc.empty:
        return pd.DataFrame()

    # Categorical 타입 컬럼 전부 str로 변환 (새 값 할당 시 에러 방지)
    for col in fdc.columns:
        if hasattr(fdc[col], "cat"):
            fdc[col] = fdc[col].astype(str)

    # act_time datetime64 강제 변환
    fdc["act_time"] = pd.to_datetime(fdc["act_time"], errors="coerce")
    fdc = fdc.dropna(subset=["act_time"])

    # 교체 이력 조회
    hist = pd.DataFrame()
    if history_df is not None and not history_df.empty:
        hist = history_df[
            (history_df["equip_id"]  == equip_id.upper()) &
            (history_df["chamber"]   == chamber.upper()) &
            (history_df["part_name"] == part_name.upper())
        ].copy()
        hist["change_date"] = pd.to_datetime(hist["change_date"], errors="coerce")
        hist = hist[
            (hist["change_date"] >= start_ts) &
            (hist["change_date"] <= end_ts)
        ].sort_values("change_date").reset_index(drop=True)

    # 교체 이력 없으면 → 전체 기간 데이터 표시
    if hist.empty:
        fdc = fdc[
            (fdc["act_time"] >= start_ts) &
            (fdc["act_time"] <= end_ts)
        ].copy()
        fdc["change_date"]  = pd.NaT
        fdc["before_after"] = "전체"
        fdc["event_label"]  = "{}-{} {} (교체이력없음)".format(equip_id, chamber, param_name)
        return fdc

    # 교체 이력 있으면 → Before/After 분류 (전체 기간 사용)
    # 교체날짜가 여러 개면 가장 최근 교체일 기준으로만 분류
    change_date = hist.iloc[-1]["change_date"]  # 가장 최근 교체일
    window = fdc[
        (fdc["act_time"] >= start_ts) &
        (fdc["act_time"] <= end_ts)
    ].copy()
    if window.empty:
        return pd.DataFrame()
    window["change_date"]  = change_date
    window["before_after"] = (window["act_time"] >= change_date).map(
        {True: "After", False: "Before"}
    )
    window["event_label"] = "{}-{} {} ({})".format(
        equip_id, chamber,
        hist.iloc[-1]["part_name"],
        change_date.strftime("%Y.%m.%d"),
    )
    return window


def mark_out_of_spec(df):
    df = df.copy()
    df["out_of_spec"] = False
    df.loc[df["upper_spec"].notna() & (df["param_value"] > df["upper_spec"]), "out_of_spec"] = True
    df.loc[df["lower_spec"].notna() & (df["param_value"] < df["lower_spec"]), "out_of_spec"] = True
    return df


def calc_statistics(df):
    stats = {}
    for event_label, group in df.groupby("event_label"):
        stats[event_label] = {}
        ba_list = group["before_after"].unique().tolist()  # group 기준으로 수정
        for ba in ba_list:
            data = group[group["before_after"] == ba]["param_value"].dropna()
            if data.empty:
                stats[event_label][ba] = None
                continue
            oos = int(group[(group["before_after"] == ba) & (group["out_of_spec"])]["param_value"].count())
            stats[event_label][ba] = {
                "mean":  round(data.mean(), 4),
                "std":   round(data.std(),  4) if len(data) > 1 else 0.0,
                "min":   round(data.min(),  4),
                "max":   round(data.max(),  4),
                "count": len(data),
                "oos":   oos,
            }
        b = stats[event_label].get("Before")
        a = stats[event_label].get("After")
        if b is not None and a is not None and abs(b["mean"]) > 1e-10:
            stats[event_label]["change_rate"] = round(
                (a["mean"] - b["mean"]) / abs(b["mean"]) * 100, 2
            )
        else:
            stats[event_label]["change_rate"] = None
    return stats


def to_timestamp_ms(dt):
    return int(pd.Timestamp(dt).timestamp() * 1000)


