MAX_ROWS = 50_000  # 최대 조회 건수

def _build_sql_base(equip_id, chamber, date_cond, param_in, ch_filter):
    """공통 SQL 베이스 생성"""
    return (
        "WITH unnested AS ("
        "  SELECT eqp_id, disp_name, step_seq, ppid, lotid, wafer_no, slot_no, recipeid,"
        "    unnest(act_time) AS act_time,"
        "    unnest(param_name) AS param_name,"
        "    unnest(ch_step) AS ch_step,"
        "    unnest(param_value) AS param_value,"
        "    unnest(upper_spec) AS upper_spec,"
        "    unnest(lower_spec) AS lower_spec"
        "  FROM fab.m_erdtsum_data_agg"
        "  WHERE line_id IN ('PFBP','PFPB') AND eqp_id='{}'"
        "    AND disp_name='{}' AND lottype<>'-' AND area='CVD' AND {}"
        ") SELECT * FROM unnested"
        " WHERE UPPER(param_name) IN ({}) {}"
    ).format(equip_id, chamber, date_cond, param_in, ch_filter)


def _postprocess(result):
    """조회 결과 공통 후처리 - Categorical 타입 포함 전체 정규화"""
    # Categorical 컬럼 전부 str로 먼저 변환 (이후 fillna/astype 에러 방지)
    for c in result.columns:
        if hasattr(result[c], "cat"):
            result[c] = result[c].astype(str)

    result["act_time"]    = pd.to_datetime(result["act_time"], errors="coerce")
    result["equip_id"]    = result["eqp_id"].astype(str).str.strip().str.upper()
    result["chamber"]     = result["disp_name"].astype(str).str.strip().str.upper()
    result["param_name"]  = result["param_name"].astype(str).str.strip().str.upper()
    result["param_value"] = pd.to_numeric(result["param_value"], errors="coerce")
    result["upper_spec"]  = pd.to_numeric(result["upper_spec"],  errors="coerce")
    result["lower_spec"]  = pd.to_numeric(result["lower_spec"],  errors="coerce")
    result = result.dropna(subset=["act_time", "param_value"])
    result = result.drop_duplicates(
        subset=["equip_id", "chamber", "act_time", "param_name", "ch_step"]
    ).reset_index(drop=True)
    return result


def fetch_fdc(equip_id, chamber, param_names, ch_steps, change_dates, start_dt, end_dt):
    if not BDQ_OK:
        return pd.DataFrame()

    param_in = ", ".join(["'{}'".format(p) for p in param_names])
    start_ts = pd.Timestamp(start_dt)
    end_ts   = pd.Timestamp(end_dt)

    date_cond = "create_time >= '{}' AND create_time <= '{}'".format(
        start_ts.strftime("%Y-%m-%d %H:%M:%S"),
        end_ts.strftime("%Y-%m-%d %H:%M:%S"),
    )
    ch_filter = ""
    if ch_steps:
        ch_filter = "AND ch_step IN ({})".format(
            ", ".join(["'{}'".format(s) for s in ch_steps])
        )

    # ── ① COUNT 사전 체크 ──────────────────────────────────────
    count_sql = (
        "WITH unnested AS ("
        "  SELECT unnest(act_time) AS act_time,"
        "    unnest(param_name) AS param_name,"
        "    unnest(ch_step) AS ch_step"
        "  FROM fab.m_erdtsum_data_agg"
        "  WHERE line_id IN ('PFBP','PFPB') AND eqp_id='{}'"
        "    AND disp_name='{}' AND lottype<>'-' AND area='CVD' AND {}"
        ") SELECT COUNT(*) AS cnt FROM unnested"
        " WHERE UPPER(param_name) IN ({}) {}"
    ).format(equip_id, chamber, date_cond, param_in, ch_filter)

    total_count = 0
    try:
        cnt_result = bdq.getData(count_sql)
        if not isinstance(cnt_result, pd.DataFrame):
            cnt_result = pd.DataFrame(cnt_result)
        if not cnt_result.empty:
            total_count = int(cnt_result.iloc[0, 0])
    except Exception:
        total_count = 0  # COUNT 실패 시 그냥 전체 조회

    sampled = False

    # ── ② 건수별 분기 ─────────────────────────────────────────
    if total_count == 0 or total_count <= MAX_ROWS:
        # 전체 조회
        sql = _build_sql_base(equip_id, chamber, date_cond, param_in, ch_filter)
        try:
            result = bdq.getData(sql)
            if not isinstance(result, pd.DataFrame):
                result = pd.DataFrame(result)
        except Exception as e:
            st.error("DB 조회 오류: {}".format(e))
            return pd.DataFrame()

    else:
        # ── ③ 5만건 초과 → Before/After 균등 샘플링 ──────────
        sampled = True
        valid_dates = [d for d in change_dates
                       if start_ts <= pd.Timestamp(d) <= end_ts]

        if valid_dates:
            # 교체일 기준 Before/After 각각 절반씩
            change_date = pd.Timestamp(valid_dates[-1])
            half = MAX_ROWS // 2

            # Before: 교체일 이전 → 최신순으로 half건
            before_cond = (
                "create_time >= '{}' AND create_time < '{}'".format(
                    start_ts.strftime("%Y-%m-%d %H:%M:%S"),
                    change_date.strftime("%Y-%m-%d %H:%M:%S"),
                )
            )
            # After: 교체일 이후 → 오래된순으로 half건
            after_cond = (
                "create_time >= '{}' AND create_time <= '{}'".format(
                    change_date.strftime("%Y-%m-%d %H:%M:%S"),
                    end_ts.strftime("%Y-%m-%d %H:%M:%S"),
                )
            )

            sql_before = (
                _build_sql_base(equip_id, chamber, before_cond, param_in, ch_filter)
                + " ORDER BY act_time DESC LIMIT {}".format(half)
            )
            sql_after = (
                _build_sql_base(equip_id, chamber, after_cond, param_in, ch_filter)
                + " ORDER BY act_time ASC LIMIT {}".format(half)
            )

            parts = []
            for sql_part in [sql_before, sql_after]:
                try:
                    r = bdq.getData(sql_part)
                    if not isinstance(r, pd.DataFrame):
                        r = pd.DataFrame(r)
                    if not r.empty:
                        parts.append(r)
                except Exception as e:
                    st.warning("샘플링 조회 오류: {}".format(e))

            if not parts:
                return pd.DataFrame()
            result = pd.concat(parts, ignore_index=True)

        else:
            # 교체일 없으면 → 전체 기간 균등하게
            sql = (
                _build_sql_base(equip_id, chamber, date_cond, param_in, ch_filter)
                + " ORDER BY act_time ASC LIMIT {}".format(MAX_ROWS)
            )
            try:
                result = bdq.getData(sql)
                if not isinstance(result, pd.DataFrame):
                    result = pd.DataFrame(result)
            except Exception as e:
                st.error("DB 조회 오류: {}".format(e))
                return pd.DataFrame()

    if result.empty:
        return pd.DataFrame()

    result = _postprocess(result)

    # 샘플링 여부 + 원본 건수 세션에 저장 (UI에서 경고 표시용)
    st.session_state["last_query_count"]   = total_count
    st.session_state["last_query_sampled"] = sampled

    return result


