    add_spec_lines(fig, df)
    add_change_vlines(fig, change_dates)
    layout = base_layout(title)
    layout["xaxis"]["title"] = "act_time"
    layout["yaxis"]["title"] = param
    fig.update_layout(**layout)
    return fig


