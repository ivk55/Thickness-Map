def build_hovertemplates(df, param_name):
    """hover 텍스트 벡터 생성 (iterrows 대신 str 연산으로 빠름)"""
    na = "N/A"
    def col(c):
        if c in df.columns:
            # astype(str) 먼저 → Categorical 타입 해제 후 fillna
            # (fillna 먼저 하면 Categorical에 새 카테고리 추가 불가 에러 발생)
            s = df[c].astype(str)
            s = s.replace("nan", na).replace("<NA>", na).replace("NaT", na)
            return s
        return pd.Series(na, index=df.index)

    val_str = df["param_value"].round(4).astype(str)
    hover = (
        "<b>" + col("event_label") + "</b><br>"
        + "시간: " + col("act_time") + "<br>"
        + param_name + ": " + val_str + "<br>"
        + "Before/After: " + col("before_after") + "<br>"
        + "Spec: " + col("lower_spec") + " ~ " + col("upper_spec") + "<br>"
        + "PPID: " + col("ppid") + "<br>"
        + "Recipe: " + col("recipeid") + "<br>"
        + "LotID: " + col("lotid") + "<br>"
