def render_stat_cards(stats):
    for event_label, s in stats.items():
        st.markdown("**{}**".format(event_label))
        b = s.get("Before") if s.get("Before") is not None else s.get("전체")
        a = s.get("After")
        cols = st.columns(4)
        with cols[0]:
            val = b["mean"] if b else "N/A"
            st.markdown("""<div class="stat-card">
                <div class="stat-label">교체 전 AVG</div>
                <div class="stat-value blue">{}</div>
                <div class="stat-sub">std {} · N={}</div>
            </div>""".format(
                val,
                b["std"] if b else "-",
                b["count"] if b else "-",
            ), unsafe_allow_html=True)
        with cols[1]:
            val = a["mean"] if a else "N/A"
            st.markdown("""<div class="stat-card">
                <div class="stat-label">교체 후 AVG</div>
                <div class="stat-value red">{}</div>
                <div class="stat-sub">std {} · N={}</div>
            </div>""".format(
                val,
                a["std"] if a else "-",
                a["count"] if a else "-",
            ), unsafe_allow_html=True)
        with cols[2]:
            cr = s.get("change_rate")
            if cr is not None:
                arrow = "▲" if cr > 0 else "▼"
                cls   = "green" if cr > 0 else "red"
                val   = "{} {:.2f}%".format(arrow, abs(cr))
            else:
                cls = "yellow"; val = "N/A"
            st.markdown("""<div class="stat-card">
                <div class="stat-label">변화율</div>
                <div class="stat-value {}">{}</div>
                <div class="stat-sub">교체 후 - 교체 전</div>
            </div>""".format(cls, val), unsafe_allow_html=True)
        with cols[3]:
            b_cnt = b["count"] if b else 0
            a_cnt = a["count"] if a else 0
            total = b_cnt + a_cnt
            st.markdown("""<div class="stat-card">
                <div class="stat-label">FDC 데이터 건수</div>
                <div class="stat-value yellow">{}건</div>
                <div class="stat-sub">교체 전 {} · 교체 후 {}</div>
            </div>""".format(total, b_cnt, a_cnt), unsafe_allow_html=True)


