def _wafer_sort_key(wafer_id: str):
    """웨이퍼 ID 정렬용 키 생성 - 개선된 버전"""
    wafer_id_str = str(wafer_id).strip()
    
    # 1. 숫자로 시작하는 경우 (예: "1", "2", "10")
    if wafer_id_str.isdigit():
        return (0, int(wafer_id_str))
    
    # 2. 소수점이 있는 경우 (예: "1.5", "2.3")
    try:
        num = float(wafer_id_str)
        if not num.is_integer():
            return (1, num)
    except ValueError:
        pass
    
    # 3. 숫자로 끝나는 경우 (예: "Slot1", "W1")
    match = re.search(r"(\d+(?:\.\d+)?)\s*$", wafer_id_str)
    if match:
        num_str = match.group(1)
        try:
            num = float(num_str) if "." in num_str else int(num_str)
            return (2, num)
        except ValueError:
            pass
    
    # 4. 그 외 (문자열 그대로)
    return (3, wafer_id_str)
