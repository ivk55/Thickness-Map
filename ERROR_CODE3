def get_latest_wafer_data(
    df: pd.DataFrame,
    prc_ppid: str,
    item_ids: List[str],
    subitem_pattern: str,
    expected_count: int,
    step_seq_list: List[str],
    measurement_config: dict,
) -> Tuple[List[List[Optional[float]]], List[str]]:
    """
    slot_order  지정 시 → 정렬된 슬롯 목록에서 해당 인덱스(1-based) 사용
    skip_slots + take_slots 지정 시 → 정렬 후 앞 skip개 제외, 다음 take개 사용
    """
    mask = (
        (df["prc_ppid"] == prc_ppid)
        & (df["item_id"].isin(item_ids))
        & (df["subitem_id"].str.fullmatch(subitem_pattern))
        & (df["step_seq"].isin(step_seq_list))
    )
    filtered = df.loc[mask].copy()
    
    # 디버깅: 필터링된 데이터 확인
    print(f"    🔍 {prc_ppid} {item_ids} 필터링 결과: {len(filtered)} rows")
    if not filtered.empty:
        print(f"       prc_tkin_time 범위: {filtered['prc_tkin_time'].min()} ~ {filtered['prc_tkin_time'].max()}")
        print(f"       고유 subitem_id: {sorted(filtered['subitem_id'].unique())}")
        print(f"       고유 slot_id: {sorted(filtered['prc_slot_id'].unique())}")
    
    if filtered.empty:
        n = measurement_config.get("take_slots", len(measurement_config.get("slot_order", [])))
        print(f"⚠️ {prc_ppid} {item_ids} 데이터가 없습니다.")
        return [[] for _ in range(n)], ["" for _ in range(n)]
    
    latest_time = filtered["prc_tkin_time"].max()
    latest = filtered[filtered["prc_tkin_time"] == latest_time].copy()
    
    # 디버깅: 최신 데이터 확인
    print(f"    📅 최신 시간: {latest_time}")
    print(f"       최신 데이터: {len(latest)} rows")
    print(f"       최신 데이터의 slot_id: {sorted(latest['prc_slot_id'].unique())}")
    
    slot_col = "prc_slot_id" if "prc_slot_id" in latest.columns else "npw_wafer_id"
    if slot_col not in latest.columns:
        print("⚠️ 웨이퍼 구분 컬럼이 없습니다.")
        n = measurement_config.get("take_slots", len(measurement_config.get("slot_order", [])))
        return [[] for _ in range(n)], ["" for _ in range(n)]
    
    if isinstance(latest[slot_col].dtype, pd.CategoricalDtype):
        latest[slot_col] = latest[slot_col].cat.remove_unused_categories()
    latest[slot_col] = latest[slot_col].astype(str)
    
    slot_groups = latest.groupby(slot_col, observed=True)
    slot_ids_all = sorted(slot_groups.groups.keys(), key=_wafer_sort_key)
    
    # 디버깅: 슬롯 정렬 확인
    print(f"    🎯 정렬된 슬롯 ID: {slot_ids_all}")
    
    # 슬롯 선택 방식 결정
    if "skip_slots" in measurement_config:
        skip = measurement_config["skip_slots"]
        take = measurement_config["take_slots"]
        slot_ids_selected = slot_ids_all[skip: skip + take]
    else:
        slot_order = measurement_config["slot_order"]
        slot_ids_selected = [
            slot_ids_all[i - 1] for i in slot_order if i <= len(slot_ids_all)
        ]
        # slot_order보다 실제 슬롯이 부족하면 빈 값으로 채움
        while len(slot_ids_selected) < len(slot_order):
            slot_ids_selected.append(None)
    
    # 디버깅: 선택된 슬롯 확인
    print(f"    ✅ 선택된 슬롯: {slot_ids_selected}")
    
    result_wafers = []
    wafer_ids = []
    
    for slot_idx, slot_id in enumerate(slot_ids_selected):
        if slot_id is None:
            result_wafers.append([])
            wafer_ids.append("")
            continue
        
        wafer = slot_groups.get_group(slot_id).copy()
        wafer_ids.append(slot_id)
        wafer["sub_num"] = wafer["subitem_id"].str.extract(r"S0?(\d+)").astype(int)
        wafer = wafer.sort_values("sub_num")
        
        # 디버깅: 웨이퍼 데이터 확인
        print(f"       Slot {slot_idx + 1} (ID: {slot_id}): {len(wafer)} rows")
        print(f"          sub_num 범위: {wafer['sub_num'].min()} ~ {wafer['sub_num'].max()}")
        print(f"          subitem_id: {sorted(wafer['subitem_id'].tolist())}")
        
        values = []
        for j in range(1, expected_count + 1):
            row = wafer[wafer["sub_num"] == j]
            if not row.empty:
                raw_val = row["value"].iloc[0]
                if pd.isna(raw_val) or raw_val in ("", "NULL"):
                    values.append(None)
                else:
                    try:
                        values.append(float(raw_val))
                    except (ValueError, TypeError):
                        values.append(None)
            else:
                values.append(None)
        
        # 디버깅: 값 확인
        non_null_count = sum(1 for v in values if v is not None)
        print(f"          데이터: {non_null_count}/{expected_count}개 유효")
        if non_null_count > 0:
            print(f"          값: {[v for v in values if v is not None][:5]}...")  # 처음 5개만
        
        result_wafers.append(values)
    
    return result_wafers, wafer_ids
