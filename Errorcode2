def _to_upper_list(inp: str, allowed: List[str]) -> List[str]:
    """쉼표‑구분 문자열을 대문자로 정규화하고 허용값만 남김"""
    if not inp:
        return []
    return [x.upper() for x in inp.split(",") if x.strip().upper() in allowed]

def select_equipment_and_chamber() -> Tuple[List[str], List[str], List[str], List[int]]:
    """콘솔 UI로 장비, 챔버, 컨테이너, SLOT 선택"""
    all_equipment = []
    for eq_type, eqp_list in EQUIPMENT_DEFINITIONS.items():
        all_equipment.extend(eqp_list)

    available_chambers = ["A", "B", "D"]

    print("=" * 80)
    print("🏭 THK Backup – 실시간 데이터 백업 시스템")
    print("=" * 80)

    print(f"\n📋 사용 가능한 설비:")
    for eq_type, eqp_list in EQUIPMENT_DEFINITIONS.items():
        print(f"   {eq_type}: {', '.join(eqp_list)}")

    equipment_input = input(
        "\n🔧 사용할 장비를 입력 (쉼표 구분, 예: TAHP857 혹은 TAHP701,TAKP851): "
    ).strip()
    selected_eqp = _to_upper_list(equipment_input, all_equipment)
    if not selected_eqp:
        selected_eqp = ["TAHP857"]
    print(f"   → 선택된 장비: {selected_eqp}")

    print(f"\n🏠 사용 가능한 챔버: {', '.join(available_chambers)}")
    chamber_input = input("🔧 사용할 챔버를 입력 (쉼표 구분, 예: A): ").strip()
    selected_ch = _to_upper_list(chamber_input, available_chambers)
    if not selected_ch:
        selected_ch = ["A"]
    print(f"   → 선택된 챔버: {selected_ch}")

    container_input = input(
        "\n🔧(선택) 컨테이너 ID 입력 (예: C001,C002, 없으면 전체): "
    ).strip()
    selected_cont = [c.strip() for c in container_input.split(",")] if container_input else []
    print(f"   → 선택된 컨테이너: {selected_cont if selected_cont else '전체'}")

    slot_input = input("\n🔧(선택) SLOT 번호 입력 (예: 1,2,3, 없으면 전체): ").strip()
    selected_slots = [int(s) for s in slot_input.split(",") if s.strip().isdigit()] if slot_input else []
    print(f"   → 선택된 SLOT: {selected_slots if selected_slots else '전체'}")
    print("\n" + "=" * 80)

    return selected_eqp, selected_ch, selected_cont, selected_slots

def determine_equipment_type(eqp_id: str) -> str:
    """설비 ID로부터 설비 타입 자동 판별"""
    for eq_type, eqp_list in EQUIPMENT_DEFINITIONS.items():
        if eqp_id in eqp_list:
            return eq_type
    return "UNKNOWN"

def fetch_raw_data(
    days: int = 14,
    equipment_ids: List[str] | None = None,
    chamber_ids: List[str] | None = None,
    container_ids: List[str] | None = None,
    slot_numbers: List[int] | None = None,
) -> Tuple[pd.DataFrame, Optional[pd.Timestamp]]:
    """DB에서 실시간 데이터 조회"""
    try:
        bdq.getData("SELECT 1")
    except Exception:
        print("▶ AD 로그인 필요 → 터미널에 계정·비밀번호 입력")
        bdq.login()

    if equipment_ids is None:
        equipment_ids = ["TAHP857"]
    if chamber_ids is None:
        chamber_ids = ["A"]
    if container_ids is None:
        container_ids = []
    if slot_numbers is None:
        slot_numbers = []

    equip_str = "','".join(equipment_ids)
    chamber_str = "','".join(chamber_ids)
    container_str = "','".join(container_ids)
    start_expr = f"DATE_SUB(NOW(), INTERVAL {days} DAY)"
    end_expr = "NOW()"

    slot_filter = ""
    if slot_numbers:
        slot_list = ",".join(map(str, slot_numbers))
        slot_filter = f"AND A.prc_slot_id IN ({slot_list})"

    query = f"""
SELECT
    A.prc_tkin_time, A.step_seq, A.eqp_id, A.tkin_time,
    A.tkin_time AS metro_tkin_time, A.container_id, A.prc_eqp_id,
    A.chamber_ids, A.prc_ppid, A.shelf_id, A.npw_wafer_id, A.prc_slot_id,
    CONCAT(A.container_id, '_', A.shelf_id) AS npw,
    B.item_id, B.subitem_id, B.value
FROM
( SELECT
    npw_wafer_id, step_seq, eqp_id, tkin_time, container_id, prc_eqp_id,
    prc_ppid, shelf_id, prc_tkin_time, dcol_time,
    chamber_id_list AS chamber_ids, prc_slot_id
  FROM yms_me_main_rt.sor_trk_fab_met_npw
  WHERE dcol_time BETWEEN {start_expr} AND {end_expr}
    AND (line_id LIKE 'P%' OR line_id LIKE 'K%')
    AND SUBSTR(line_id,3,1) <> 'R'
    AND prc_tkin_time BETWEEN {start_expr} AND {end_expr}
    AND prc_eqp_id IN ('{equip_str}')
    AND chamber_id_list IN ('{chamber_str}')
    {"AND container_id IN ('" + container_str + "')" if container_str else ""}
    {slot_filter}
    AND shelf_id IS NOT NULL
) A
LEFT JOIN
( SELECT
    npw_wafer_id, step_seq, item_id, sub_item_id AS subitem_id,
    item_value AS value, dcol_time
  FROM yms_me_main_rt.sor_trk_fab_met_npw_msr
  WHERE dcol_time BETWEEN {start_expr} AND {end_expr}
    AND ( SUBSTR(item_id,1,2) IN ('TH','RI','RK','GO','B1','P1')
          OR item_id IN ('WARPCF_X','BOW1_1') )
    AND SUBSTR(sub_item_id,1,1) IN ('S','A','R')
    AND sub_item_id NOT IN ('STD','SLOTID','SKEW')
) B ON A.npw_wafer_id = B.npw_wafer_id AND A.dcol_time = B.dcol_time
WHERE B.item_id IS NOT NULL;
"""

    print("\n▶ 데이터 조회 중…")
    df = bdq.getData(query)
    print(f"✅ 조회완료: {len(df)} rows, {len(df.columns)} columns")

    for col in ("prc_tkin_time", "dcol_time"):
        if col in df.columns:
            df[col] = pd.to_datetime(df[col], errors="coerce")
            if df[col].dt.tz is None:
                df[col] = df[col].dt.tz_localize("UTC")

    fetch_ts = datetime.utcnow().replace(tzinfo=pd.Timestamp.utcnow().tz)
    df["fetch_timestamp"] = fetch_ts

    latest_tkin_time: Optional[pd.Timestamp] = None
    if "tkin_time" in df.columns:
        df["tkin_time"] = pd.to_datetime(df["tkin_time"], errors="coerce")
        if df["tkin_time"].dt.tz is None:
            df["tkin_time"] = df["tkin_time"].dt.tz_localize("UTC")
        latest_tkin_time = df["tkin_time"].max()

    return df, latest_tkin_time

def _wafer_sort_key(wafer_id: str):
    """웨이퍼 ID 정렬용 키 생성"""
    match = re.search(r"(\d+(?:\.\d+)?)\s*$", str(wafer_id))
    if match:
        num_str = match.group(1)
        try:
            return float(num_str) if "." in num_str else int(num_str)
        except ValueError:
            pass
    return wafer_id

def get_latest_wafer_data(
    df: pd.DataFrame,
    prc_ppid: str,
    item_ids: List[str],
    subitem_pattern: str,
    expected_count: int,
    step_seq_list: List[str],
    slot_order: List[int],
    strict: bool = True,
) -> Tuple[List[List[Optional[float]]], List[str]]:
    """설정에 따라 웨이퍼 데이터를 추출"""
    mask = (
        (df["prc_ppid"] == prc_ppid)
        & (df["item_id"].isin(item_ids))
        & (df["subitem_id"].str.fullmatch(subitem_pattern))
        & (df["step_seq"].isin(step_seq_list))
    )
    filtered = df.loc[mask].copy()
    if filtered.empty:
        print(f"⚠️ {prc_ppid} {item_ids} 데이터가 없습니다.")
        return [[] for _ in slot_order], ["" for _ in slot_order]

    latest_time = filtered["prc_tkin_time"].max()
    latest = filtered[filtered["prc_tkin_time"] == latest_time].copy()

    slot_col = "prc_slot_id" if "prc_slot_id" in latest.columns else "npw_wafer_id"
    if slot_col not in latest.columns:
        print("⚠️ 웨이퍼 구분 컬럼이 없습니다.")
        return [[] for _ in slot_order], ["" for _ in slot_order]

    if pd.api.types.is_categorical_dtype(latest[slot_col]):
        latest[slot_col] = latest[slot_col].cat.remove_unused_categories()
    latest[slot_col] = latest[slot_col].astype(str)

    slot_groups = latest.groupby(slot_col, observed=True)
    slot_ids_available = sorted(slot_groups.groups.keys(), key=_wafer_sort_key)

    result_wafers = []
    wafer_ids = []

    for slot_idx in slot_order:
        if slot_idx <= len(slot_ids_available):
            slot_id = slot_ids_available[slot_idx - 1]
            wafer = slot_groups.get_group(slot_id).copy()
            wafer_ids.append(slot_id)

            wafer["sub_num"] = wafer["subitem_id"].str.extract(r"S(\d+)").astype(int)
            wafer = wafer.sort_values("sub_num")

            values = []
            for j in range(1, expected_count + 1):
                row = wafer[wafer["sub_num"] == j]
                if not row.empty:
                    raw_val = row["value"].iloc[0]
                    if pd.isna(raw_val) or raw_val in ("", "NULL"):
                        values.append(None)
                    else:
                        try:
                            values.append(float(raw_val))
                        except (ValueError, TypeError):
                            values.append(None)
                else:
                    values.append(None)
            result_wafers.append(values)
        else:
            result_wafers.append([])
            wafer_ids.append("")

    return result_wafers, wafer_ids

def print_clean_separator(title: str = "", width: int = 80) -> None:
    """깔끔한 구분선 출력"""
    if title:
        print(f"\n{'=' * width}")
        print(f"  {title}")
        print(f"{'=' * width}")
    else:
        print(f"{'─' * width}")

def print_step_result(step_name: str, item_type: str, slot_num: int, slot_id: str,
                      data_count: int, cell_range: str, valid_count: int = None) -> None:
    """깔끔한 결과 출력"""
    status_icon = "✅" if (valid_count or data_count) > 0 else "❌"
    print(f"  Step {step_name} | {item_type} | Slot {slot_num} (ID: {slot_id}) | {data_count}개 데이터 → {cell_range} {status_icon}")
    if valid_count is not None and valid_count < data_count:
        missing = data_count - valid_count
        print(f"    ⚠️  누락된 데이터: {missing}개")

def get_cell_range_from_start(start_cell: str, count: int) -> str:
    """시작 셀과 개수로부터 범위 문자열 생성"""
    match = re.match(r"([A-Z]+)(\d+)", start_cell)
    if not match:
        return start_cell

    col, row = match.groups()
    start_row = int(row)
    end_row = start_row + count - 1
    return f"{col}{start_row}:{col}{end_row}"

def write_to_excel_by_equipment(
    all_data: Dict[str, Dict[str, List[List[Optional[float]]]]],
    equipment_types: Dict[str, List[str]],
    fetch_timestamp: datetime,
    tkin_timestamp: Optional[pd.Timestamp] = None,
) -> Dict[str, Dict[str, Dict[str, List[str]]]]:
    """설비별 Excel 파일에 데이터 저장"""

    written_cells_by_equipment = {}

    for eq_type, eqp_list in equipment_types.items():
        if eq_type not in EQUIPMENT_FILES:
            print(f"⚠️ {eq_type}에 해당하는 Excel 파일이 없습니다.")
            continue

        src_file = EQUIPMENT_FILES[eq_type]["src"]
        dst_file = EQUIPMENT_FILES[eq_type]["dst"]

        if not src_file.exists():
            print(f"❌ 원본 파일이 없습니다: {src_file}")
            continue

        dst_file.parent.mkdir(parents=True, exist_ok=True)

        print(f"📁 {eq_type} 설비 → {dst_file.name}")
        written_cells_by_equipment[eq_type] = {}

        app = xw.App(visible=False)
        try:
            wb = app.books.open(str(src_file))
            sht = wb.sheets[0]

            sht.range("A1").value = f"Data fetched (UTC) : {fetch_timestamp}"
            if tkin_timestamp is not None:
                sht.range("B1").value = f"Latest tkin_time (UTC) : {tkin_timestamp}"
            else:
                sht.range("B1").value = "Latest tkin_time (UTC) : N/A"

            eq_cell_mapping = EXCEL_CELL_MAPPING.get(eq_type, {})

            for prc_ppid, items in all_data.items():
                if prc_ppid not in eq_cell_mapping:
                    continue

                written_cells_by_equipment[eq_type][prc_ppid] = {}

                for item_type, wafer_lists in items.items():
                    if item_type not in eq_cell_mapping[prc_ppid]:
                        continue

                    cells = eq_cell_mapping[prc_ppid][item_type]
                    written_cells_by_equipment[eq_type][prc_ppid][item_type] = []

                    for wafer_idx, (cell, values) in enumerate(zip(cells, wafer_lists)):
                        if not values:
                            written_cells_by_equipment[eq_type][prc_ppid][item_type].append("")
                            continue

                        excel_vals = [v if v is not None else "" for v in values]
                        sht.range(cell).options(transpose=True).value = excel_vals

                        data_count = len(values)
                        cell_range = get_cell_range_from_start(cell, data_count)
                        written_cells_by_equipment[eq_type][prc_ppid][item_type].append(cell_range)

            wb.save(str(dst_file))
            print(f"  ✅ 저장 완료: {dst_file}")

        except Exception as e:
            print(f"  ❌ {eq_type} Excel 쓰기 오류: {e}")
            raise
        finally:
            wb.close()
            app.quit()

    return written_cells_by_equipment

def main() -> None:
    """메인 실행 함수"""
    DAYS = 14
    STRICT = False

    try:
        # 1️⃣ 장비 선택
        selected_eqp, selected_ch, selected_cont, selected_slots = select_equipment_and_chamber()

        # 2️⃣ DB 조회
        print("\n🔍 DB에서 데이터 조회 중...")
        df, latest_tkin_time = fetch_raw_data(
            days=DAYS,
            equipment_ids=selected_eqp,
            chamber_ids=selected_ch,
            container_ids=selected_cont,
            slot_numbers=selected_slots,
        )
        if df.empty:
            print("❌ 조회된 데이터가 없습니다.")
            return

        # 3️⃣ 선택된 장비 분석
        equipment_types = {}
        for eqp in selected_eqp:
            eq_type = determine_equipment_type(eqp)
            if eq_type not in equipment_types:
                equipment_types[eq_type] = []
            equipment_types[eq_type].append(eqp)

        print(f"\n📊 선택된 설비 타입: {list(equipment_types.keys())}")

        all_data: Dict[str, Dict[str, List[List[Optional[float]]]]] = {}
        all_wafer_ids: Dict[str, Dict[str, List[str]]] = {}

        # 4️⃣ 설정 기반 데이터 수집
        print_clean_separator("공정별 데이터 처리")

        for prc_ppid, process_config in PROCESS_CONFIGS.items():
            eq_type_required = process_config["equipment_type"]

            if eq_type_required not in equipment_types:
                continue

            print(f"\n🔹 {prc_ppid} 공정 처리 중...")
            process_data = {}
            process_wafer_ids = {}

            for measurement_type, measurement_config in process_config["measurements"].items():
                print(f"  📏 {measurement_type} 측정 중...")

                item_ids = measurement_config["item_ids"]
                step_seq = measurement_config["step_seq"]
                subitem_pattern = measurement_config["subitem_pattern"]
                expected_count = measurement_config["expected_count"]
                slot_order = measurement_config["slot_order"]

                wafer_values, wafer_ids = get_latest_wafer_data(
                    df, prc_ppid, item_ids, subitem_pattern, expected_count, step_seq, slot_order, STRICT
                )

                process_data[measurement_type] = wafer_values
                process_wafer_ids[measurement_type] = wafer_ids

                valid_slots = sum(1 for values in wafer_values if values)
                print(f"    ✅ {valid_slots}/{len(slot_order)} 슬롯 데이터 수집 완료")

            all_data[prc_ppid] = process_data
            all_wafer_ids[prc_ppid] = process_wafer_ids

        # 5️⃣ 설비별 Excel 파일에 저장
        if all_data:
            fetch_ts = df["fetch_timestamp"].iloc[0]
            print_clean_separator("설비별 Excel 파일 저장")

            written_cells_by_equipment = write_to_excel_by_equipment(
                all_data, equipment_types, fetch_timestamp=fetch_ts, tkin_timestamp=latest_tkin_time
            )

            # 6️⃣ 상세 결과 출력
            print_clean_separator("📊 백업 완료 - 상세 결과")

            for eq_type in equipment_types.keys():
                if eq_type in written_cells_by_equipment:
                    print(f"\n📁 설비 타입: {eq_type}")
                    print(f"   파일: {EQUIPMENT_FILES[eq_type]['dst'].name}")

                    for prc_ppid, process_data in written_cells_by_equipment[eq_type].items():
                        print(f"\n🔹 공정: {prc_ppid}")

                        for item_type, cell_ranges in process_data.items():
                            process_config = PROCESS_CONFIGS.get(prc_ppid, {})
                            measurement_config = process_config.get("measurements", {}).get(item_type, {})
                            step_seq_list = measurement_config.get("step_seq", ["UNKNOWN"])
                            step_name = step_seq_list[0]

                            wafer_ids = all_wafer_ids.get(prc_ppid, {}).get(item_type, [])
                            wafer_data = all_data.get(prc_ppid, {}).get(item_type, [])

                            for slot_idx, (cell_range, slot_data) in enumerate(zip(cell_ranges, wafer_data)):
                                if cell_range and slot_data:
                                    slot_id = wafer_ids[slot_idx] if slot_idx < len(wafer_ids) else "N/A"
                                    valid_count = sum(1 for v in slot_data if v is not None)
                                    data_count = len(slot_data)

                                    print_step_result(
                                        step_name, item_type, slot_idx + 1, slot_id,
                                        data_count, cell_range, valid_count
                                    )

            # 7️⃣ 최종 요약
            print_clean_separator()
            print("🎉 THK Backup 자동화 성공!")
            saved_files = [EQUIPMENT_FILES[eq_type]['dst'].name for eq_type in equipment_types.keys() if eq_type in EQUIPMENT_FILES]
            print(f"💾 저장된 파일: {', '.join(saved_files)}")
            print(f"📂 저장 위치: {AFTER_DIR}")
            print(f"📊 처리된 설비: {list(equipment_types.keys())}")
            print(f"🔧 처리된 공정: {list(all_data.keys())}")

            print(f"\n💡 설정 힌트:")
            print(f"   - 슬롯 순서 변경: PROCESS_CONFIGS에서 'slot_order' 수정")
            print(f"   - 셀 위치 변경: EXCEL_CELL_MAPPING에서 셀 좌표 수정")
            print(f"   - 새 설비 추가: 코드 상단의 설정 섹션 참고")
        else:
            print("\n⚠️ 저장할 데이터가 없습니다.")

    except Exception as exc:
        print(f"❌ 오류 발생: {exc}", file=sys.stderr)
        traceback.print_exc()


