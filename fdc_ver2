// plotly div 렌더 완료 후 실행 보장
function waitForPlotly(callback) {{
  var attempts = 0;
  var timer = setInterval(function() {{
    var gd = document.getElementById("plotly-chart");
    if (gd && gd.data && gd.data.length > 0) {{
      clearInterval(timer);
      callback(gd);
    }}
    if (++attempts > 50) clearInterval(timer);
  }}, 100);
}}

// Step 필터 - legendgroup 기준
function filterByStep(step) {{
  var gd = document.getElementById("plotly-chart");
  var updates = [];
  for (var i = 0; i < gd.data.length; i++) {{
    var lg = gd.data[i].legendgroup || "";
    var visible;
    if (step === "ALL") {{
      visible = true;
    }} else {{
      visible = (lg.indexOf(step) !== -1) ? true : "legendonly";
    }}
    updates.push(visible);
  }}
  Plotly.restyle(gd, {{visible: updates}});
}}

// 날짜 범위 적용 - ISO 형식
function applyDateRange() {{
  var gd = document.getElementById("plotly-chart");
  var s = document.getElementById("date-start").value;
  var e = document.getElementById("date-end").value;
  if (!s || !e) {{ alert("시작일과 종료일을 모두 입력해줘!"); return; }}
  if (s >= e) {{ alert("종료일이 시작일보다 앞이야!"); return; }}
  Plotly.relayout(gd, {{
    "xaxis.range": [s + "T00:00:00", e + "T23:59:59"]
  }});
}}

// 날짜 전체 원복
function resetDateRange() {{
  var gd = document.getElementById("plotly-chart");
  document.getElementById("date-start").value = "";
  document.getElementById("date-end").value   = "";
  Plotly.relayout(gd, {{"xaxis.autorange": true}});
}}

