# ① Line Plot
def chart_line(df, param, steps, mode, change_dates, title, stat_text, out_dir):
    legend_shown = set()

    if mode == "overlay":
        fig = go.Figure()
        for step in steps:
            sdf = df[df["ch_step"] == step] if step != "ALL" else df
            step_label = "" if step == "ALL" else " [{}]".format(step)

            for ba, color in [("Before", COLOR_BEFORE), ("After", COLOR_AFTER)]:
                in_s, out_s = split_in_out(sdf, ba)
                in_s  = in_s.sort_values("act_time")
                out_s = out_s.sort_values("act_time")
                name_in  = "{}{} In Spec".format(ba, step_label)
                name_oos = "{}{} OOS".format(ba, step_label)

                if not in_s.empty:
                    fig.add_trace(go.Scatter(
                        x=in_s["act_time"], y=in_s["param_value"],
                        mode="lines+markers",
                        name=name_in,
                        legendgroup=name_in,
                        showlegend=(name_in not in legend_shown),
                        line=dict(color=color, width=2),
                        marker=dict(size=5, color=color),
                        hovertemplate=build_hovertemplates(in_s, param),
                    ))
                    legend_shown.add(name_in)
                if not out_s.empty:
                    fig.add_trace(go.Scatter(
                        x=out_s["act_time"], y=out_s["param_value"],
                        mode="markers",
                        name=name_oos,
                        legendgroup=name_oos,
                        showlegend=(name_oos not in legend_shown),
                        marker=dict(size=9, color=COLOR_OUT_SPEC, symbol="x"),
                        hovertemplate=build_hovertemplates(out_s, param),
                    ))
                    legend_shown.add(name_oos)

        add_spec_shapes(fig, df)
        add_change_vlines(fig, change_dates)
        fig.update_layout(**base_layout(title, stat_text))
        fig.update_xaxes(**range_selector_xaxis())
        fig.update_yaxes(title_text=param)

    else:  # subplot
        n  = len(steps)
        vs = 0.05 if n == 1 else min(0.07, 1.0 / (n - 1))
        fig = make_subplots(
            rows=n, cols=1,
            subplot_titles=["ch_step: {}".format(s) for s in steps],
            vertical_spacing=vs,
        )

        for ri, step in enumerate(steps, start=1):
            sdf = df[df["ch_step"] == step] if step != "ALL" else df
            for ba, color in [("Before", COLOR_BEFORE), ("After", COLOR_AFTER)]:
                in_s, out_s = split_in_out(sdf, ba)
                in_s  = in_s.sort_values("act_time")
                out_s = out_s.sort_values("act_time")
                name_in  = "{} In Spec".format(ba)
                name_oos = "{} OOS".format(ba)

                if not in_s.empty:
                    fig.add_trace(go.Scatter(
                        x=in_s["act_time"], y=in_s["param_value"],
                        mode="lines+markers",
                        name=name_in,
                        legendgroup=name_in,
                        showlegend=(name_in not in legend_shown),
                        line=dict(color=color, width=2),
                        marker=dict(size=5, color=color),
                        hovertemplate=build_hovertemplates(in_s, param),
                    ), row=ri, col=1)
                    legend_shown.add(name_in)
                if not out_s.empty:
                    fig.add_trace(go.Scatter(
                        x=out_s["act_time"], y=out_s["param_value"],
                        mode="markers",
                        name=name_oos,
                        legendgroup=name_oos,
                        showlegend=(name_oos not in legend_shown),
                        marker=dict(size=9, color=COLOR_OUT_SPEC, symbol="x"),
                        hovertemplate=build_hovertemplates(out_s, param),
                    ), row=ri, col=1)
                    legend_shown.add(name_oos)
            add_spec_shapes(fig, sdf, row_idx=ri, col=1)
            add_change_vlines(fig, change_dates, row=ri, col=1)

        fig.update_layout(**base_layout(title, stat_text, height=max(500, 400*n)))
        fig.update_yaxes(title_text=param)
        fig.update_xaxes(**range_selector_xaxis(), row=n, col=1)
        fig.update_xaxes(title_text="act_time", row=1, col=1)

    save_show(fig, title, out_dir, steps=steps)


