waitForPlotly(function(gd) {{
  var allX = [];
  gd.data.forEach(function(t) {{ if (t.x) allX = allX.concat(t.x); }});
  if (allX.length === 0) return;
  var dates = allX.map(function(d) {{
    return new Date(typeof d === "string" ? d.replace(" ", "T") : d);
  }}).filter(function(d) {{ return !isNaN(d.getTime()); }});
  if (dates.length === 0) return;
  var minD = new Date(Math.min.apply(null, dates));
  var maxD = new Date(Math.max.apply(null, dates));
  document.getElementById("date-start").value = minD.toISOString().slice(0, 10);
  document.getElementById("date-end").value   = maxD.toISOString().slice(0, 10);
}});
</script>
