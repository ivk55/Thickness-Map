def make_hover(row, param_name):
    """pandas Series → hover 문자열 (safe_val로 KeyError 방지)"""
    parts = [
        "<b>" + safe_val(row, "event_label") + "</b>",
        "시간: " + str(row["act_time"]),
        param_name + ": " + str(round(float(row["param_value"]), 4)),
        "Before/After: " + safe_val(row, "before_after"),
        "Spec: " + safe_val(row, "lower_spec") + " ~ " + safe_val(row, "upper_spec"),
        "PPID: " + safe_val(row, "ppid"),
        "Recipe: " + safe_val(row, "recipeid"),
        "LotID: " + safe_val(row, "lotid"),
        "Wafer No: " + safe_val(row, "wafer_no"),
        "Slot No: " + safe_val(row, "slot_no"),
        "Step Seq: " + safe_val(row, "step_seq"),
    ]
    return "<br>".join(parts) + "<extra></extra>"


def build_hovertemplates(df, param_name):
    """DataFrame 전체 → hover 리스트 (iterrows 한번만 호출)"""
    return [make_hover(row, param_name) for _, row in df.iterrows()]


def add_spec_shapes(fig, df, row_idx=None, col=1, domains=None):
    """
    Upper/Lower Spec 라인 추가
    - 단순 figure: add_hline 사용
    - subplot: yref="y" / "y2" 등으로 정확히 지정
    domains 파라미터는 호환성 유지용으로만 남겨둠 (실제 미사용)
    """
    upper = df["upper_spec"].dropna()
    lower = df["lower_spec"].dropna()

    def _add(val, label):
        if row_idx is not None:
            # subplot 모드: yref를 해당 subplot 축으로 지정
            yr = "y" if row_idx == 1 else "y{}".format(row_idx)
            fig.add_shape(
                type="line",
                xref="paper", yref=yr,
                x0=0, x1=1, y0=val, y1=val,
                line=dict(dash="dot", color=COLOR_SPEC, width=1.5),
            )
            fig.add_annotation(
                xref="paper", yref=yr,
                x=1.01, y=val,
                text=label, showarrow=False,
                font=dict(color=COLOR_SPEC, size=9),
            )
        else:
            # 단순 figure: add_hline 사용
            fig.add_hline(
                y=val,
                line_dash="dot", line_color=COLOR_SPEC, line_width=1.5,
                annotation_text=label, annotation_position="right",
            )

    if not upper.empty:
        _add(round(upper.mean(), 4), "USL:{}".format(round(upper.mean(), 4)))
    if not lower.empty:
        _add(round(lower.mean(), 4), "LSL:{}".format(round(lower.mean(), 4)))


def add_change_vlines(fig, change_dates, row=None, col=None):
    """교체 시점 세로선 (timestamp*1000 으로 TypeError 방지)"""
    kwargs = {"row": row, "col": col} if row is not None else {}
    for cd in change_dates:
        fig.add_vline(
            x=to_timestamp_ms(cd),
            line_dash="dot", line_color=COLOR_CHANGE, line_width=2,
            **kwargs
        )


