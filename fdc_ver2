def save_show(fig, title, output_dir, steps=None):
    """
    fig 저장 + 표시
    steps: ch_step 목록 (Step 드롭다운 UI 생성용, None이면 UI 없음)
    """
    os.makedirs(output_dir, exist_ok=True)
    safe = (title
            .replace(" ", "_").replace("/", "-").replace(":", "-")
            .replace("[","").replace("]","").replace("~","-"))
    path = os.path.join(output_dir, "{}.html".format(safe))

    config = {
        "scrollZoom": True,
        "displayModeBar": True,
        "modeBarButtonsToRemove": ["select2d", "lasso2d"],
        "toImageButtonOptions": {
            "format": "png",
            "filename": safe,
            "scale": 2,
        },
    }

    try:
        if steps and len(steps) > 1 and steps != ["ALL"]:
            # Step 드롭다운 + 날짜 UI 삽입
            html_str = fig.to_html(
                include_plotlyjs="cdn",
                div_id="plotly-chart",
                config=config,
            )
            custom_ui = build_custom_ui(steps)
            html_str = html_str.replace("<body>", "<body>" + custom_ui)
            with open(path, "w", encoding="utf-8") as f:
                f.write(html_str)
        else:
            fig.write_html(path, config=config)
        print("    → HTML 저장: {}".format(path))
    except Exception as e:
        print("    → 저장 실패: {}".format(e))
    fig.show(config=config)


def split_in_out(df, ba):
    """Before/After 중 In Spec / Out of Spec 분리"""
    sub = df[df["before_after"] == ba]
    return sub[~sub["out_of_spec"]].copy(), sub[sub["out_of_spec"]].copy()


