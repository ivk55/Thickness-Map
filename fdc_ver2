            start_dt.strftime("%Y.%m.%d %H:%M:%S"),
            end_dt.strftime("%Y.%m.%d %H:%M:%S"),
            diff.days, diff.seconds // 3600,
        ))
        if input("  맞아? (y/n) >> ").strip().lower() == "y":
            return start_dt, end_dt
        print("  다시 입력할게.\n")


