def extract_before_after(fdc_df, history_df, equip_id, chamber, part_name, param_name, start_dt, end_dt):
    hist = history_df[
        (history_df["equip_id"]  == equip_id.upper()) &
        (history_df["chamber"]   == chamber.upper()) &
        (history_df["part_name"] == part_name.upper())
    ].copy()

    if hist.empty:
        print("  [경고] 교체 이력 없음")
        return pd.DataFrame()

    start_ts = pd.Timestamp(start_dt)
    end_ts   = pd.Timestamp(end_dt)

    hist = hist[
        (hist["change_date"] >= start_ts) &
        (hist["change_date"] <= end_ts)
    ].sort_values("change_date").reset_index(drop=True)

    if hist.empty:
        print("  [경고] 기간 내 교체 없음")
        return pd.DataFrame()

    fdc = fdc_df[fdc_df["param_name"] == param_name.upper()].copy()
    if fdc.empty:
        print("  [경고] FDC 없음: {}".format(param_name))
        return pd.DataFrame()

    results = []
    n = len(hist)

    for i in range(n):
        change_date  = hist.iloc[i]["change_date"]
        window_start = start_ts if i == 0   else hist.iloc[i-1]["change_date"]  # iloc 사용
        window_end   = end_ts   if i == n-1 else hist.iloc[i+1]["change_date"]  # iloc 사용

        window = fdc[
            (fdc["act_time"] >= window_start) &
            (fdc["act_time"] <= window_end)
        ].copy()

        if window.empty:
            continue

        window["change_date"]  = change_date
        window["before_after"] = (window["act_time"] >= change_date).map(
            {True: "After", False: "Before"}
        )
        window["event_label"] = "{}-{} {} ({})".format(
            equip_id, chamber,
            hist.iloc[i]["part_name"],
            change_date.strftime("%Y.%m.%d"),
        )
        results.append(window)

    if not results:
        print("  [경고] Before/After 없음")
        return pd.DataFrame()

    return pd.concat(results, ignore_index=True)


