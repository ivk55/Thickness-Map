# ⑨ Control Chart (SPC)
def chart_control(df, param, change_dates, title, stat_text, out_dir, steps=None):
    fig = go.Figure()
    for ba, color in [("Before", COLOR_BEFORE), ("After", COLOR_AFTER)]:
        sub = df[df["before_after"] == ba].sort_values("act_time")
        if sub.empty:
            continue
        mean = sub["param_value"].mean()
        std  = sub["param_value"].std()
        # std NaN 방어 (데이터 1개일 때)
        if pd.isna(std) or std == 0:
            std = 0.0

        in_s, out_s = split_in_out(sub, ba)
        if not in_s.empty:
            fig.add_trace(go.Scatter(
                x=in_s["act_time"], y=in_s["param_value"],
                mode="lines+markers", name=ba,
                line=dict(color=color, width=1.5),
                marker=dict(size=5, color=color),
                hovertemplate=build_hovertemplates(in_s, param),
            ))
        if not out_s.empty:
            fig.add_trace(go.Scatter(
                x=out_s["act_time"], y=out_s["param_value"],
                mode="markers", name="{} OOS".format(ba),
                marker=dict(size=10, color=COLOR_OUT_SPEC, symbol="x"),
                hovertemplate=build_hovertemplates(out_s, param),
            ))

        for y_val, label, dash in [
            (mean,           "Mean({})={:.3f}".format(ba, mean),       "dash"),
            (mean + 3 * std, "+3σ({})={:.3f}".format(ba, mean+3*std),  "dot"),
            (mean - 3 * std, "-3σ({})={:.3f}".format(ba, mean-3*std),  "dot"),
        ]:
            fig.add_hline(
                y=y_val, line_dash=dash, line_color=color, line_width=1,
                annotation_text=label, annotation_position="right",
            )

    add_spec_shapes(fig, df)
    add_change_vlines(fig, change_dates)
    fig.update_layout(**base_layout(title, stat_text))
    fig.update_xaxes(**range_selector_xaxis())
    fig.update_yaxes(title_text=param)
    save_show(fig, title, out_dir, steps=steps)


# ⑩ 변화율 Bar Chart
def chart_change_rate(df, param, title, stat_text, out_dir):
    events, rates, colors = [], [], []
    for event_label, group in df.groupby("event_label"):
        b = group[group["before_after"] == "Before"]["param_value"].mean()
        a = group[group["before_after"] == "After"]["param_value"].mean()
        if pd.notna(b) and pd.notna(a) and b != 0:
            rate = (a - b) / abs(b) * 100
            events.append(event_label)
            rates.append(round(rate, 2))
            colors.append(COLOR_AFTER if rate > 0 else COLOR_BEFORE)

    if not events:
        print("  [경고] 변화율 데이터 없음")
        return

    fig = go.Figure(go.Bar(
        x=events, y=rates,
        marker_color=colors, opacity=0.85,
        text=["{}%".format(r) for r in rates],
        textposition="outside",
        hovertemplate="이벤트: %{x}<br>변화율: %{y:.2f}%<extra></extra>",
    ))
    fig.add_hline(y=0, line_color="black", line_width=1)
    fig.update_layout(**base_layout(title, stat_text))
    fig.update_yaxes(title_text="변화율 (%)")
    save_show(fig, title, out_dir)


