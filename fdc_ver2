def get_subplot_domains(n_rows, vert_spacing):
    """각 subplot의 (bottom, top) y 도메인 반환 (row1=맨위 순서)"""
    if n_rows == 1:
        return [(0.0, 1.0)]
    total_spacing = vert_spacing * (n_rows - 1)
    row_height    = (1.0 - total_spacing) / n_rows
    domains = []
    for i in range(n_rows):
        top    = 1.0 - i * (row_height + vert_spacing)
        bottom = top - row_height
        domains.append((round(bottom, 4), round(top, 4)))
    return domains


