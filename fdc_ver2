def input_datetime(prompt):
    formats = [
        "%Y-%m-%d %H:%M:%S", "%Y-%m-%d %H:%M", "%Y-%m-%d",
        "%Y/%m/%d %H:%M:%S", "%Y/%m/%d %H:%M", "%Y/%m/%d",
    ]
    while True:
        raw = input("  {}\n  >> ".format(prompt)).strip()
        for fmt in formats:
            try:
                return datetime.strptime(raw, fmt)
            except ValueError:
                continue
        print("  [오류] 예) 2026-01-31 08:30:00  또는  2026-01-31")


def input_period():
    print("\n" + "="*55)
    print("  조회 기간 입력")
    print("="*55)
    while True:
        start_dt = input_datetime("시작 날짜시간")
        while True:
            end_dt = input_datetime("종료 날짜시간")
            if end_dt > start_dt:
                break
            print("  [오류] 종료가 시작보다 앞이야. 종료만 다시 입력해줘.\n")
        diff = end_dt - start_dt
