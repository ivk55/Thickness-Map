def fetch_fdc_data(equip_id, chamber, param_names, ch_steps, change_dates, start_dt, end_dt):
    print("\n[2] FDC 데이터 조회 중...")
    try:
        bdq.getData("SELECT 1")
    except Exception:
        print("    → AD 로그인 필요")
        bdq.login()

    param_in   = ", ".join(["'{}'".format(p) for p in param_names])
    total_days = (end_dt - start_dt).days
    half_days  = max(1, total_days // 2)
    start_ts   = pd.Timestamp(start_dt)
    end_ts     = pd.Timestamp(end_dt)
    valid_dates = [d for d in change_dates if start_ts <= d <= end_ts]

    if valid_dates:
        parts = []
        for d in valid_dates:
            s = max(start_ts, d - pd.Timedelta(days=half_days)).strftime("%Y-%m-%d %H:%M:%S")
            e = min(end_ts,   d + pd.Timedelta(days=half_days)).strftime("%Y-%m-%d %H:%M:%S")
            parts.append("(create_time >= '{}' AND create_time <= '{}')".format(s, e))
        date_cond = "({})".format(" OR ".join(parts))
    else:
        print("  [안내] 전체 기간 조회")
        date_cond = "create_time >= '{}' AND create_time <= '{}'".format(
            start_ts.strftime("%Y-%m-%d %H:%M:%S"),
            end_ts.strftime("%Y-%m-%d %H:%M:%S"),
        )

    ch_filter = ""
    if ch_steps:
        ch_filter = "AND ch_step IN ({})".format(
            ", ".join(["'{}'".format(s) for s in ch_steps])
        )

    sql = (
        "WITH unnested AS ("
        "  SELECT eqp_id, disp_name, step_seq, ppid, lotid, wafer_no, slot_no, recipeid,"
        "    unnest(act_time) AS act_time,"
        "    unnest(param_name) AS param_name,"
        "    unnest(ch_step) AS ch_step,"
        "    unnest(param_value) AS param_value,"
        "    unnest(upper_spec) AS upper_spec,"
        "    unnest(lower_spec) AS lower_spec"
        "  FROM fab.m_erdtsum_data_agg"
        "  WHERE line_id IN ('PFBP','PFPB') AND eqp_id='{}'"
        "    AND disp_name='{}' AND lottype<>'-' AND area='CVD' AND {}"
        ") SELECT * FROM unnested"
        " WHERE UPPER(param_name) IN ({}) {}"
    ).format(equip_id, chamber, date_cond, param_in, ch_filter)

    try:
        result = bdq.getData(sql)
        if not isinstance(result, pd.DataFrame):
            result = pd.DataFrame(result)
    except Exception as e:
        print("  [오류] {}".format(e))
        return pd.DataFrame()

    if result.empty:
        print("    → [경고] 데이터 없음")
        return pd.DataFrame()

    result["act_time"]    = pd.to_datetime(result["act_time"], errors="coerce")
    result["equip_id"]    = result["eqp_id"].str.strip().str.upper()
    result["chamber"]     = result["disp_name"].str.strip().str.upper()
    result["param_name"]  = result["param_name"].str.strip().str.upper()
    result["param_value"] = pd.to_numeric(result["param_value"], errors="coerce")
    result["upper_spec"]  = pd.to_numeric(result["upper_spec"],  errors="coerce")
    result["lower_spec"]  = pd.to_numeric(result["lower_spec"],  errors="coerce")
    result = result.dropna(subset=["act_time", "param_value"])
    result = result.drop_duplicates(
        subset=["equip_id", "chamber", "act_time", "param_name", "ch_step"]
    ).reset_index(drop=True)

    print("    → {}건 로드 완료 (중복 제거 후)".format(len(result)))
    return result


