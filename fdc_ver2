def to_timestamp_ms(dt):
    """pd.Timestamp → plotly용 ms 정수 변환"""
    return int(pd.Timestamp(dt).timestamp() * 1000)


# ============================================================
# 헬퍼: Series에서 안전하게 값 가져오기
# ============================================================

def safe_val(series_row, key, default="N/A"):
    """pandas Series에서 안전하게 값 추출 (v1 KeyError 방지)"""
    try:
        val = series_row[key]
        return str(val) if pd.notna(val) else default
    except (KeyError, TypeError):
        return default


