def load_history_excel(path):
    print("\n[1] Excel 이력 로드 중...")
    if not os.path.exists(path):
        print("  [오류] 파일 없음: {}".format(path))
        exit()
    app = xw.App(visible=False)
    try:
        wb       = app.books.open(path)
        all_data = []
        for sheet in wb.sheets:
            try:
                last_row = sheet.range("A1").end("down").row
                if last_row < 2:
                    continue
                data = sheet.range("A2:E{}".format(last_row)).value
                for row in data:
                    if not row or row[0] is None:
                        continue
                    all_data.append({
                        "equip_id":    str(row[0]).strip().upper(),
                        "chamber":     str(row[1]).strip().upper() if row[1] else "",
                        "part_name":   str(row[2]).strip().upper() if row[2] else "",
                        "part_type":   str(row[3]).strip()         if row[3] else "",
                        "change_date": pd.to_datetime(row[4])      if row[4] else None,
                    })
            except Exception as e:
                print("  [경고] 시트 '{}' 실패: {}".format(sheet.name, e))
        wb.close()
    finally:
        app.quit()

    if not all_data:
        print("  [오류] 데이터 없음")
        exit()
    result = pd.DataFrame(all_data).dropna(subset=["change_date"])
    print("    → {}건 로드 완료".format(len(result)))
    return result


