import org.slf4j.LoggerFactory

val logger = LoggerFactory.getLogger("EARS")

def bringToFront(user32: User32, hWnd: HWND): Unit = {

  user32.ShowWindow(hWnd, 9) // SW_RESTORE

  user32.SetForegroundWindow(hWnd)
  Thread.sleep(100)
  user32.SetForegroundWindow(hWnd)
}

def forcePopup(user32: User32, hwnd: HWND): Unit = {

  val HWND_TOPMOST   = new HWND(Pointer.createConstant(-1))
  val HWND_NOTOPMOST = new HWND(Pointer.createConstant(-2))

  val SWP_FLAGS = 0x0001 | 0x0002 | 0x0040

  user32.ShowWindow(hwnd, WinUser.SW_RESTORE)
  Thread.sleep(50)

  user32.ShowWindow(hwnd, WinUser.SW_MAXIMIZE)
  Thread.sleep(50)

  user32.SetWindowPos(
    hwnd,
    HWND_TOPMOST,
    0, 0, 0, 0,
    SWP_FLAGS
  )
  user32.SetForegroundWindow(hwnd)
  Thread.sleep(50)

  Thread.sleep(100)

  user32.SetWindowPos(
    hwnd,
    HWND_NOTOPMOST,
    0, 0, 0, 0,
    SWP_FLAGS
  )
  user32.SetForegroundWindow(hwnd)
}

def wrapper(args: List[String]): (Boolean, String, Map[String, String]) = {
  try {

    val user32 = User32.INSTANCE

    var targetHwnd: HWND = null
    var foundTitle: String = ""

    val keyword = if (args.nonEmpty) args.head else "localhost"

    val enumProc = new WinUser.WNDENUMPROC {
      override def callback(hWnd: HWND, data: Pointer): Boolean = {

        val titleArr: Array[Char] = Array.fill(512)('\u0000')
        val classArr: Array[Char] = Array.fill(512)('\u0000')

        user32.GetWindowText(hWnd, titleArr, 512)
        user32.GetClassName(hWnd, classArr, 512)

        val title = Native.toString(titleArr)
        val cls   = Native.toString(classArr)

        //logger.info(s"[HWND] $hWnd | [CLASS] $cls | [TITLE] $title")

	    if (title != null &&
	        title.contains("localhost") &&
	        title.trim.nonEmpty) {
	
	      targetHwnd = hWnd
	        }
	        true
      }
    }

    user32.EnumWindows(enumProc, null)

    if (targetHwnd == null) {
      return (
        false,
        "failed: TITLE is not found",
        Map("keyword" -> keyword)
      )
    }

    logger.info("select HWND: " + targetHwnd)
    logger.info("select TITLE: " + foundTitle)

	forcePopup(user32, targetHwnd)
	
    (
      true,
      "Success: top_max_fix",
      Map(
        "title" -> foundTitle,
        "keyword" -> keyword
      )
    )

    (true, s"Success", Map.empty[String, String])
  }
  catch {
    case ex: Exception =>
      logger.error("Exception:", ex)
      (false, ex.getMessage, Map.empty[String, String])
  }
}
wrapper _ 
